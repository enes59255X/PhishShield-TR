{
  "manifest_version": 3,
  "name": "PhishShield TR - Autonomous",
  "version": "2.0.0",
  "description": "Otonom ve kendi kendine öğrenen phishing tespit sistemi",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "notifications",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8004/*",
    "http://127.0.0.1:8004/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://127.0.0.1:8004 http://localhost:8004"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
